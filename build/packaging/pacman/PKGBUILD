pkgname=opencode
pkgver=1.2.10
pkgrel=1
pkgdesc='OpenCode for Termux from local staged prefix'
arch=('aarch64')
url='https://github.com/anomalyco/opencode'
license=('MIT')
options=('!strip' '!debug')

makedepends=()
source=()
sha256sums=()

_prefix="${PREFIX:-/data/data/com.termux/files/usr}"
_repo_root="${REPO_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"
_staged_prefix="${STAGED_PREFIX:-${_repo_root}/artifacts/staged/prefix}"

prepare() {
  [[ -x "${_staged_prefix}/lib/opencode/runtime/opencode" ]] || {
    error "missing runtime at ${_staged_prefix}/lib/opencode/runtime/opencode"
    return 1
  }
  [[ -x "${_staged_prefix}/bin/opencode" ]] || {
    error "missing launcher at ${_staged_prefix}/bin/opencode"
    return 1
  }
}

build() {
  true
}

package() {
  mkdir -p "$pkgdir${_prefix}"
  cp -a "${_staged_prefix}/." "$pkgdir${_prefix}/"
}

post_install() {
  echo "OpenCode for Termux installed"
  echo "Run: opencode --version"
  local hook_runner="${PREFIX:-/data/data/com.termux/files/usr}/lib/opencode/tools/run-system-skills.sh"
  if [[ -x "$hook_runner" ]]; then
    OPENCODE_HOOK_STRICT=0 OPENCODE_HOOK_ENABLE_NETWORK=0 "$hook_runner" post_install || true
  fi
}

post_upgrade() {
  local hook_runner="${PREFIX:-/data/data/com.termux/files/usr}/lib/opencode/tools/run-system-skills.sh"
  if [[ -x "$hook_runner" ]]; then
    OPENCODE_HOOK_STRICT=0 OPENCODE_HOOK_ENABLE_NETWORK=0 "$hook_runner" post_upgrade || true
  fi
}

pre_remove() {
  local hook_runner="${PREFIX:-/data/data/com.termux/files/usr}/lib/opencode/tools/run-system-skills.sh"
  if [[ -x "$hook_runner" ]]; then
    OPENCODE_HOOK_STRICT=0 OPENCODE_HOOK_ENABLE_NETWORK=0 "$hook_runner" pre_remove || true
  fi
}

post_remove() {
  local hook_runner="${PREFIX:-/data/data/com.termux/files/usr}/lib/opencode/tools/run-system-skills.sh"
  if [[ -x "$hook_runner" ]]; then
    OPENCODE_HOOK_STRICT=0 OPENCODE_HOOK_ENABLE_NETWORK=0 "$hook_runner" post_remove || true
  fi
}
