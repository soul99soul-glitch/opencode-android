{
  "$schema": "https://opencode.ai/system-skill.schema.json",
  "id": "oh-my-opencode",
  "name": "oh-my-opencode",
  "version": "1",
  "plugin_id": "oh-my-opencode",
  "repo": "https://github.com/code-yeongyu/oh-my-opencode.git",
  "enabled": true,
  "events": [
    "post_install",
    "post_upgrade",
    "pre_remove",
    "post_remove"
  ],
  "default_enable": false,
  "auto_install_latest": false,
  "auto_update": false,
  "minimum_core_version": "1.2.0",
  "maximum_core_version": "2.0.0",
  "blocked_core_versions": [],
  "idempotency_key": "opencode-system-skill-omo-v1",
  "policy": "warn",
  "notes": "Default is safe registration/verification only. Enable networked auto install/update with OPENCODE_HOOK_ENABLE_NETWORK=1."
}
