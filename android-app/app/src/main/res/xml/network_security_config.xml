<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Android network-security-config cannot express RFC1918 CIDR ranges.
        LAN mode accepts user-entered private IPs, so platform cleartext stays
        available and OpenCodeApi/LocalProviderModelFetcher reject public HTTP
        before sending prompts, auth headers, or provider API keys.
    -->
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">githubusercontent.com</domain>
        <domain includeSubdomains="true">objects.githubusercontent.com</domain>
    </domain-config>
</network-security-config>
